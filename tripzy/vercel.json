{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/tripzy/browser",
  "framework": "angular",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "env": {
    "BLOB_READ_WRITE_TOKEN": "@blob_read_write_token"
  }
}
