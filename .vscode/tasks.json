{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "API: Start",
      "type": "shell",
      "command": "node dev-api.js",
      "options": { "cwd": "${workspaceFolder}/tripzy" },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": { "regexp": "Local API server running" },
          "endsPattern":   { "regexp": "XXXXNEVER" }
        }
      },
      "presentation": {
        "label": "API :3002",
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Angular: Start",
      "type": "shell",
      "command": "npx ng serve",
      "options": { "cwd": "${workspaceFolder}/tripzy" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": { "regexp": "Building\\.\\.\\." },
          "endsPattern":   { "regexp": "bundle generation complete" }
        }
      },
      "presentation": {
        "label": "Angular :4200",
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Dev: Start All",
      "dependsOrder": "parallel",
      "dependsOn": ["API: Start", "Angular: Start"],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Build: Production",
      "type": "shell",
      "command": "npx ng build --configuration=production",
      "options": { "cwd": "${workspaceFolder}/tripzy" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    }
  ]
}
